datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AssociationStatus {
  ACTIVE
  INACTIVE
}

enum AccessCodeStatus {
  PENDING
  USED
  EXPIRED
}

enum UserRole {
  ADMIN
  MANAGER
  RESIDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CodeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CorrectionRequestStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Association {
  id           String            @id @default(uuid())
  name         String
  code         String            @unique
  email        String
  phone        String?
  status       AssociationStatus @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  accessCodes  AccessCode[]
  users        User[]
  codeRequests CodeRequest[]
  documents    Document[]
}

model AccessCode {
  id            String           @id @default(uuid())
  associationId String
  association   Association      @relation(fields: [associationId], references: [id], onDelete: Cascade)
  code          String           @unique
  memberName    String
  email         String
  phone         String?
  status        AccessCodeStatus @default(PENDING)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  users         User[]
}

model User {
  id                  String               @id @default(uuid())
  associationId       String?
  association         Association?         @relation(fields: [associationId], references: [id], onDelete: SetNull)
  accessCodeId        String?              @unique
  accessCode          AccessCode?          @relation(fields: [accessCodeId], references: [id], onDelete: SetNull)
  firstName           String
  lastName            String
  email               String               @unique
  phone               String?
  passwordHash        String
  role                UserRole             @default(RESIDENT)
  status              UserStatus           @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  correctionRequests  CorrectionRequest[]
  documentsUploaded   Document[]
  maintenanceRequests MaintenanceRequest[]
  notifications       Notification[]
}

model CodeRequest {
  id            String            @id @default(uuid())
  associationId String
  association   Association       @relation(fields: [associationId], references: [id], onDelete: Cascade)
  name          String
  email         String
  phone         String?
  status        CodeRequestStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model CorrectionRequest {
  id               String                  @id @default(uuid())
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedName    String
  requestedAddress String
  reason           String
  status           CorrectionRequestStatus @default(PENDING)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model Document {
  id            String      @id @default(uuid())
  associationId String
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  fileUrl       String
  uploadedById  String
  uploadedBy    User        @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model MaintenanceRequest {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
